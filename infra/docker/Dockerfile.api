FROM python:3.12-slim

WORKDIR /app

RUN pip install --no-cache-dir uv

COPY pyproject.toml ./
RUN uv pip install --system -e .

COPY apps /app/apps
COPY packages /app/packages

ENV PYTHONPATH=/app

EXPOSE 8000

CMD ["uvicorn", "apps.api.shuyuan_core.app:app", "--host", "0.0.0.0", "--port", "8000"]

          "type": "integer"
        },
        "token_add": {
          "minimum": 0,
          "title": "Token Add",
          "type": "integer"
        },
        "tool_add": {
          "minimum": 0,
          "title": "Tool Add",
          "type": "integer"
        }
      },
      "required": [
        "token_add",
        "time_add_s",
        "tool_add"
      ],
      "title": "BudgetRequested",
      "type": "object"
    }

        },
        "token_cap": {
          "minimum": 0,
          "title": "Token Cap",
          "type": "integer"
        },
        "token_used": {
          "minimum": 0,
          "title": "Token Used",
          "type": "integer"
        },
        "tool_cap": {
          "minimum": 0,
          "title": "Tool Cap",
          "type": "integer"
        },
        "tool_used": {
          "minimum": 0,
          "title": "Tool Used",
          "type": "integer"
        }

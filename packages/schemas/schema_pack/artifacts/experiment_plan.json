{
  "$defs": {
    "ExperimentMetrics": {
      "additionalProperties": false,
      "properties": {
        "guardrail": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Guardrail",
          "type": "array"
        },
        "primary": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Primary",
          "type": "array"
        }
      },
      "required": [
        "primary",
        "guardrail"
      ],
      "title": "ExperimentMetrics",
      "type": "object"
    },
    "Rollout": {
      "additionalProperties": false,
      "properties": {
        "ab_ratio": {
          "maximum": 1,
          "minimum": 0,
          "title": "Ab Ratio",
          "type": "number"
        },
        "duration_days": {
          "minimum": 1,
          "title": "Duration Days",
          "type": "integer"
        },
        "target_population": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Target Population"
        }
      },
      "required": [
        "ab_ratio",
        "duration_days"
      ],
      "title": "Rollout",
      "type": "object"
    }
  },
  "$id": "https://shuyuan.ai/schema/artifacts/experiment_plan.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "change": {
      "title": "Change",
      "type": "string"
    },
    "ext": {
      "additionalProperties": true,
      "title": "Ext",
      "type": "object"
    },
    "hypothesis": {
      "title": "Hypothesis",
      "type": "string"
    },
    "metrics": {
      "$ref": "#/$defs/ExperimentMetrics"
    },
    "rollback_thresholds": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Rollback Thresholds",
      "type": "array"
    },
    "rollout": {
      "$ref": "#/$defs/Rollout"
    }
  },
  "required": [
    "change",
    "hypothesis",
    "metrics",
    "rollout",
    "rollback_thresholds"
  ],
  "title": "ExperimentPlanBody",
  "type": "object"
}

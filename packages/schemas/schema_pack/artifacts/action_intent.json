{
  "$defs": {
    "RuntimePhase": {
      "enum": [
        "observe",
        "sanitize",
        "freeze_state",
        "plan_action",
        "preview",
        "commit",
        "checkpoint",
        "resume"
      ],
      "title": "RuntimePhase",
      "type": "string"
    }
  },
  "$id": "https://shuyuan.ai/schema/artifacts/action_intent.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "action_target": {
      "title": "Action Target",
      "type": "string"
    },
    "action_type": {
      "title": "Action Type",
      "type": "string"
    },
    "affordances": {
      "items": {
        "type": "string"
      },
      "title": "Affordances",
      "type": "array"
    },
    "checkpoint_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Checkpoint Id"
    },
    "ext": {
      "additionalProperties": true,
      "title": "Ext",
      "type": "object"
    },
    "intent_summary": {
      "title": "Intent Summary",
      "type": "string"
    },
    "observation_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Observation Hash"
    },
    "parent_snapshot_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Parent Snapshot Id"
    },
    "requires_frozen_snapshot": {
      "title": "Requires Frozen Snapshot",
      "type": "boolean"
    },
    "resume_from_checkpoint_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Resume From Checkpoint Id"
    },
    "runtime_phase": {
      "$ref": "#/$defs/RuntimePhase"
    },
    "runtime_session_id": {
      "title": "Runtime Session Id",
      "type": "string"
    },
    "side_effect_level": {
      "enum": [
        "none",
        "read_only",
        "internal_write",
        "external_write",
        "external_commit"
      ],
      "title": "Side Effect Level",
      "type": "string"
    },
    "snapshot_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Snapshot Id"
    },
    "source_channel": {
      "enum": [
        "gui",
        "web",
        "api",
        "terminal",
        "other"
      ],
      "title": "Source Channel",
      "type": "string"
    },
    "taint_flags": {
      "items": {
        "type": "string"
      },
      "title": "Taint Flags",
      "type": "array"
    },
    "trust_level": {
      "enum": [
        "untrusted",
        "tainted",
        "trusted",
        "verified"
      ],
      "title": "Trust Level",
      "type": "string"
    }
  },
  "required": [
    "runtime_session_id",
    "runtime_phase",
    "source_channel",
    "trust_level",
    "intent_summary",
    "action_type",
    "action_target",
    "side_effect_level",
    "requires_frozen_snapshot"
  ],
  "title": "ActionIntentBody",
  "type": "object"
}

{
  "$defs": {
    "RuntimePhase": {
      "enum": [
        "observe",
        "sanitize",
        "freeze_state",
        "plan_action",
        "preview",
        "commit",
        "checkpoint",
        "resume"
      ],
      "title": "RuntimePhase",
      "type": "string"
    }
  },
  "$id": "https://shuyuan.ai/schema/artifacts/observation_assessment.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "affordance_integrity": {
      "enum": [
        "intact",
        "degraded",
        "spoofed"
      ],
      "title": "Affordance Integrity",
      "type": "string"
    },
    "affordances": {
      "items": {
        "type": "string"
      },
      "title": "Affordances",
      "type": "array"
    },
    "assessed_at": {
      "format": "date-time",
      "title": "Assessed At",
      "type": "string"
    },
    "checkpoint_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Checkpoint Id"
    },
    "ext": {
      "additionalProperties": true,
      "title": "Ext",
      "type": "object"
    },
    "observation_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Observation Hash"
    },
    "parent_snapshot_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Parent Snapshot Id"
    },
    "recommendation": {
      "title": "Recommendation",
      "type": "string"
    },
    "resume_from_checkpoint_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Resume From Checkpoint Id"
    },
    "runtime_phase": {
      "$ref": "#/$defs/RuntimePhase"
    },
    "runtime_session_id": {
      "title": "Runtime Session Id",
      "type": "string"
    },
    "snapshot_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Snapshot Id"
    },
    "source_channel": {
      "enum": [
        "gui",
        "web",
        "api",
        "terminal",
        "other"
      ],
      "title": "Source Channel",
      "type": "string"
    },
    "state_drift_risk": {
      "enum": [
        "low",
        "med",
        "high",
        "critical"
      ],
      "title": "State Drift Risk",
      "type": "string"
    },
    "taint_detected": {
      "title": "Taint Detected",
      "type": "boolean"
    },
    "taint_flags": {
      "items": {
        "type": "string"
      },
      "title": "Taint Flags",
      "type": "array"
    },
    "taint_reasons": {
      "items": {
        "type": "string"
      },
      "title": "Taint Reasons",
      "type": "array"
    },
    "trust_level": {
      "enum": [
        "untrusted",
        "tainted",
        "trusted",
        "verified"
      ],
      "title": "Trust Level",
      "type": "string"
    },
    "trusted_observation_minimum": {
      "title": "Trusted Observation Minimum",
      "type": "boolean"
    }
  },
  "required": [
    "runtime_session_id",
    "runtime_phase",
    "source_channel",
    "trust_level",
    "assessed_at",
    "taint_detected",
    "trusted_observation_minimum",
    "state_drift_risk",
    "affordance_integrity",
    "recommendation"
  ],
  "title": "ObservationAssessmentBody",
  "type": "object"
}
